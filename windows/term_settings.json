        },
        {
            "id": "Terminal.DuplicatePaneRight",
            "keys": "ctrl+shift+5"
        },
        {
            "id": "Terminal.NextTab",
            "keys": "ctrl+shift+n"
        },
        {
            "id": "User.openTabRenamer",
            "keys": "ctrl+shift+r"
        },
        {
            "id": "Terminal.MoveFocusDown",
            "keys": "ctrl+shift+j"
        },
        {
            "id": "Terminal.MoveFocusUp",
            "keys": "ctrl+shift+k"
        },
        {
            "id": "Terminal.MoveFocusLeft",
            "keys": "ctrl+shift+h"
        },
        {
            "id": "Terminal.MoveFocusRight",
            "keys": "ctrl+shift+l"
        },
        {
            "id": null,
            "keys": "enter"
        },
        {
            "id": null,
            "keys": "ctrl+insert"
        },
        {
            "id": null,
            "keys": "ctrl+tab"
        },
        {
            "id": null,
            "keys": "alt+shift+minus"
        },
        {
            "id": null,
            "keys": "alt+shift+plus"
        },
        {
            "id": null,
            "keys": "alt+down"
        },
        {
            "id": null,
            "keys": "alt+up"
        },
        {
            "id": null,
            "keys": "alt+left"
        },
        {
            "id": null,
            "keys": "alt+right"
        }
    ],
    "newTabMenu": 
    [
        {
            "type": "remainingProfiles"
        }
    ],
    "profiles": 
    {
        "defaults": 
        {
            "font": 
            {
                "cellHeight": "1.2",
                "face": "CaskaydiaMono Nerd Font",
                "size": 12,
                "weight": "medium"
            },
            "historySize": 3000,
            "opacity": 85,
            "padding": "4",
            "scrollbarState": "hidden",
            "startingDirectory": "%USERPROFILE%",
            "useAcrylic": false
        },
